{{> layout/header}}

<div class="container my-3">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>번호</th>
                <th>제목</th>
                <th>작성자</th>
                <th>작성일</th>
            </tr>
        </thead>
        <tbody>
            {{#model.boardList}}
            <tr>
                <td>{{id}}</td>
                <td>{{title}}</td>
                <td>{{username}}</td>
                <td>{{createdAt}}</td>
            </tr>
            {{/model.boardList}}
        </tbody>
    </table>

    <!-- 페이징 UI -->
    <ul class="pagination justify-content-center">
        <!-- 이전 버튼 -->
        <li class="page-item {{#model.pagination.isFirst}}disabled{{/model.pagination.isFirst}}">
            <a class="page-link" href="?page={{model.pagination.prevPage}}">이전</a>
        </li>

        <!-- 앞쪽 ... 표시 -->
        {{#model.pagination.showPrevDots}}
        <li class="page-item disabled">
            <span class="page-link">...</span>
        </li>
        {{/model.pagination.showPrevDots}}

        <!-- 페이지 번호 목록 -->
        {{#model.pagination.pageNumbers}}
        <li class="page-item {{#isCurrent}}active{{/isCurrent}}">
            <a class="page-link" href="?page={{number}}">{{number}}</a>
        </li>
        {{/model.pagination.pageNumbers}}

        <!-- 뒤쪽 ... 표시 -->
        {{#model.pagination.showNextDots}}
        <li class="page-item disabled">
            <span class="page-link">...</span>
        </li>
        {{/model.pagination.showNextDots}}

        <!-- 다음 버튼 -->
        <li class="page-item {{#model.pagination.isLast}}disabled{{/model.pagination.isLast}}">
            <a class="page-link" href="?page={{model.pagination.nextPage}}">다음</a>
        </li>
    </ul>
</div>

{{> layout/footer}}
