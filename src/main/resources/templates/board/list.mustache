{{> layout/header}}

<div class="container my-3">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>번호</th>
                <th>제목</th>
                <th>작성자</th>
                <th>작성일</th>
            </tr>
        </thead>
        <tbody>
            {{#boardList}}
            <tr>
                <td>{{id}}</td>
                <td>{{title}}</td>
                <td>{{username}}</td>
                <td>{{createdAt}}</td>
            </tr>
            {{/boardList}}
        </tbody>
    </table>
</div>

{{> layout/footer}}
